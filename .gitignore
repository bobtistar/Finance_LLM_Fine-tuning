# 홈 디렉토리의 모든 것을 무시하고 finance_llm만 추적
*
!finance_llm/
!finance_llm/**
!.gitignore

# finance_llm 내부에서도 제외할 항목
finance_llm/__pycache__/
finance_llm/*.pyc
finance_llm/.env
finance_llm/finance_report/output/
finance_llm/finance_report/*.pdf
finance_llm/finance_report/*.crdownload
finance_llm/finance_report/labeled_dataset.jsonl
